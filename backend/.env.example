APP_ENV=development
DEVELOPMENT_AUTH_BYPASS=true
DATABASE_URL=postgresql+psycopg://intelliglove:intelliglove@localhost:5432/intelliglove
FIREBASE_PROJECT_ID=intelligent-glove-asl-33-da1aa
FIREBASE_CREDENTIALS_PATH=
REQUIRE_VERIFIED_EMAIL=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:7358,http://127.0.0.1:7358
# Optional in production. Development/test already allow localhost, 127.0.0.1,
# and [::1] on any port in addition to CORS_ORIGINS.
CORS_ORIGIN_REGEX=
ML_SERVICE_URL=http://localhost:8080
ML_INTERNAL_API_KEY=replace-for-non-local-use
MODEL_DIR=../models
# Rate limiting is ENABLED by default outside development/test (Issue 8).
# Set to false only for local development; never disable in staging/production.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=IntelliGlove Admin
TEST_DATABASE_URL=postgresql+psycopg://intelliglove:intelliglove@localhost:5432/intelliglove_test